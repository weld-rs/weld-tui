#!/usr/bin/env bash
#
# pre-commit — runs automatically before every `git commit`.
#
# What it does:
#   1. Scans staged files for leaked secrets using Kingfisher. If valid secrets
#      are found, the commit is blocked.
#   2. Runs `cargo fmt` to auto-format all Rust code. Any files changed by the
#      formatter are staged so the commit always includes formatted code.
#      Fails if more than 3 files outside the staged set get reformatted —
#      a sign of baseline drift or unstaged WIP being silently swept up.
#
# Setup:
#   Run `just bootstrap` (or `git config core.hooksPath .githooks`) to
#   activate this hook. Requires `kingfisher` to be installed.
#
set -e

# ── Configuration ─────────────────────────────────────────────────────────────
FMT_CMD="cargo fmt"
# ──────────────────────────────────────────────────────────────────────────────

# Get git root directory and change to it
GIT_ROOT=$(git rev-parse --show-toplevel)
cd "$GIT_ROOT"

# Get staged files (Added, Copied, Modified)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
    exit 0
fi

# Secrets scanning with Kingfisher (only valid secrets)
echo "🔍 Scanning for secrets..."
STAGED_FILES_ARGS=$(echo "$STAGED_FILES" | tr '\n' ' ')
if ! kingfisher scan --only-valid $STAGED_FILES_ARGS; then
    echo ""
    echo "❌ Valid secrets detected! Commit blocked."
    echo "💡 Run: kingfisher scan --only-valid $STAGED_FILES_ARGS"
    exit 1
fi
echo "✅ No valid secrets detected"

# Auto-format all Rust code
if [ -n "$FMT_CMD" ]; then
    echo "🎨 Running formatter..."
    $FMT_CMD
    # Stage all files the formatter touched
    REFORMATTED=$(git diff --name-only -- '*.rs')
    if [ -n "$REFORMATTED" ]; then
        # Tripwire: fail if cargo fmt reformatted >3 files outside the staged set —
        # catches baseline drift or unstaged WIP being silently swept into the commit.
        STRAY_FILES=$(comm -23 \
            <(echo "$REFORMATTED" | sort -u) \
            <(echo "$STAGED_FILES" | sort -u))
        STRAY_COUNT=0
        if [ -n "$STRAY_FILES" ]; then
            STRAY_COUNT=$(echo "$STRAY_FILES" | wc -l | tr -d ' ')
        fi
        if [ "$STRAY_COUNT" -gt 3 ]; then
            echo "❌ cargo fmt reformatted $STRAY_COUNT file(s) outside the staged set:"
            echo "$STRAY_FILES" | sed 's/^/   /'
            echo ""
            echo "   This usually means baseline drift or unstaged WIP got formatted."
            echo "   Run 'cargo fmt' yourself, review the changes, and commit separately."
            exit 1
        fi
        echo "$REFORMATTED" | xargs git add
        echo "✅ Reformatted and re-staged: $(echo "$REFORMATTED" | wc -l | tr -d ' ') file(s)"
    fi
    # Belt-and-suspenders: verify everything is clean
    if ! $FMT_CMD -- --check > /dev/null 2>&1; then
        echo "❌ Formatter check failed after re-staging. Aborting commit."
        exit 1
    fi
fi
